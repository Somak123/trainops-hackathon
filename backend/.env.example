# DigitalOcean API token (used by infra/do_manager.py)
DO_TOKEN=

# Public URL of this FastAPI app (ngrok or deployed URL) — worker curls POST {PUBLIC_BACKEND_URL}/webhook/complete
PUBLIC_BACKEND_URL=https://your-subdomain.ngrok-free.app

# Optional: require droplet/webhook callers to send header X-Webhook-Secret: <value>
WEBHOOK_SECRET=

# SQLite database (path relative to cwd when starting uvicorn from backend/)
DATABASE_URL=sqlite:///./trainops.db

# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
